# Anthropic API Key（必填）
# 到 https://console.anthropic.com 取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Supabase（選填 - 不填則用 localStorage）
# 到 https://supabase.com 建立免費專案後取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxx

# 簡易密碼保護（選填 - 防止他人使用你的 API）
ACCESS_PIN=
